{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/daily-check",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/coach-weekly-tips",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/weekly-summary",
      "schedule": "5 20 * * 0"
    }
  ]
}
